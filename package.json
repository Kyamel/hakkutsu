{
  "name": "hakkutsu",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "dev:node": "tsx watch src/dev/server.ts",
    "build": "tsc --noEmit",
    "build:mobile:web": "vite build --config vite.mobile.config.ts && cp public/app.js public/styles.css dist-capacitor/",
    "build:mobile": "npm run build && npm run build:mobile:web && cap sync android",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy": "wrangler deploy --env="
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.12.27",
    "vite": "^8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@hono/node-server": "^2.0.6",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.104.0"
  }
}
