{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hakkutsu",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-06-25",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api", "/api/*"]
  },
  "env": {
    "staging": {
      "name": "hakkutsu-staging"
    }
  }
}
